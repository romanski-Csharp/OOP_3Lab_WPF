<Window x:Class="ButtonGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Генератор кнопок" Height="450" Width="800">
    <Grid>
        <Label Content="від" HorizontalAlignment="Left" Margin="100,20,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TxtFrom" HorizontalAlignment="Left" Margin="100,50,0,0" VerticalAlignment="Top" Width="80" Height="25" Text="10"/>

        <Label Content="до" HorizontalAlignment="Left" Margin="250,20,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TxtTo" HorizontalAlignment="Left" Margin="250,50,0,0" VerticalAlignment="Top" Width="80" Height="25" Text="200"/>

        <Label Content="з кроком" HorizontalAlignment="Left" Margin="400,20,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TxtStep" HorizontalAlignment="Left" Margin="400,50,0,0" VerticalAlignment="Top" Width="80" Height="25" Text="5"/>

        <Button Content="Треба більше кнопок!" HorizontalAlignment="Left" Margin="550,30,0,0" VerticalAlignment="Top" Width="150" Height="45" Click="AddButtons_Click"/>

        <Label Content="А чи не вилучити мені всі кнопки, кратні..." HorizontalAlignment="Left" Margin="100,100,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TxtMultiple" HorizontalAlignment="Left" Margin="400,100,0,0" VerticalAlignment="Top" Width="80" Height="25"/>

        <Button Content="Вилучити" HorizontalAlignment="Left" Margin="550,100,0,0" VerticalAlignment="Top" Width="150" Height="25" Click="RemoveButtons_Click"/>

        <ScrollViewer Margin="0,150,0,0" Background="Cyan">
            <WrapPanel x:Name="ButtonsContainer" Margin="5"/>
        </ScrollViewer>
    </Grid>
</Window>